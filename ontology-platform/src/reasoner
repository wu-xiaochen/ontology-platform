"""
推理引擎核心 (Reasoning Engine Core)
实现本体推理逻辑，包括传递闭包计算、查询回答和推理链传播
"""

import re
from typing import List, Dict, Optional
from collections import defaultdict
from .loader import OntologyLoader
from .confidence import ConfidenceCalculator


class Reasoner:
    """
    推理引擎
    
    支持:
    - 本体推理 (传递闭包)
    - 查询回答
    - 推理链置信度传播
    
    示例:
        loader = OntologyLoader().load("ontology.json")
        reasoner = Reasoner(loader)
        
        # 推理
        inferred = reasoner.infer("Person")
        print(f"Person 的所有子类: {inferred.classes}")
        
        # 查询
        query = {
            'subject': 'Alice',
            'predicate': 'knows',
            'object': 'Bob'
        }
        results = reasoner.query(query)
        print(f"查询结果: {results}")
        
        # 推理链置信度传播
        chain = [
            {'premise_confidence': 0.9, 'rule_confidence': 0.8},
            {'premise_confidence': 0.85, 'rule_confidence': 0.9},
            {'premise_confidence': 0.95, 'rule_confidence': 0.85}
        ]
        confidence = reasoner.propagate_confidence(chain)
        print(f"推理链置信度: {confidence:.3f}")
    """
    
    def __init__(self, ontology: OntologyLoader):
        """
        初始化
        
        Args:
            ontology: 本体加载器实例
        """
        self.ontology = ontology
        self.confidence_calculator = ConfidenceCalculator()
    
    def infer(self, class_uri: str) -> dict:
        """
        推理类
        
        Args:
            class_uri: 目标类 URI
        
        Returns:
            推理结果 (类及其子类)
        """
        # 获取目标类
        cls = self.ontology.get_class(class_uri)
        if not cls:
            raise ValueError(f"类 {class_uri} 不存在")
        
        # 获取所有子类
        subclasses = self.ontology.get_all_subclasses(class_uri)
        
        # 计算置信度
        confidence = self.confidence_calculator.calculate(
            evidence=[Evidence(source="推理", reliability=0.9, content={})],
            method="weighted"
        )
        
        return {
            'class': cls,
            'subclasses': subclasses,
            'confidence': confidence
        }
    
    def query(self, query: dict) -> list[dict]:
        """
        查询回答
        
        Args:
            query: 查询字典 (格式: {subject: URI, predicate: URI, object: URI})
        
        Returns:
            查询结果列表
        """
        # 执行查询
        results = []
        
        # 示例实现: 简单匹配
        for ind in self.ontology.individuals.values():
            if query['subject'] in ind.types:
                result = {
                    'subject': ind.uri,
                    'predicate': query['predicate'],
                    'object': ind.assertions.get(query['predicate'], '未知')
                }
                results.append(result)
        
        # 计算置信度
        confidence = self.confidence_calculator.calculate(
            evidence=[Evidence(source="查询", reliability=0.8, content=query)],
            method="weighted"
        )
        
        return results
    
    def propagate_confidence(self, chain_confidences: list[dict]) -> float:
        """
        推理链置信度传播
        
        Args:
            chain_confidences: 推理链各步骤的置信度 (格式: [{premise_confidence: float, rule_confidence: float}, ...])
        
        Returns:
            推理链整体置信度
        """
        # 计算推理链置信度
        overall = self.confidence_calculator.propagate_confidence(
            chain_confidences,
            method="min"
        )
        
        return overall


# 便捷函数
def create_reasoner(ontology_path: str) -> Reasoner:
    """
    创建推理引擎
    
    Args:
        ontology_path: 本体文件路径
    
    Returns:
        推理引擎实例
    """
    loader = OntologyLoader().load(ontology_path)
    return Reasoner(loader)


