{
  "_description": "默认反义词映射表 — 当 Neo4j 不可用时用作 ContradictionChecker 的降级方案",
  "_usage": "每个键是一个概念值，其对应的数组包含该概念的所有互斥/矛盾概念",
  "_extensibility": "可通过添加新的键值对扩展到任意领域，无需修改代码",
  "high_risk": ["safe", "low_risk"],
  "safe": ["high_risk", "danger", "hazardous"],
  "low_risk": ["high_risk", "danger"],
  "danger": ["safe", "low_risk"],
  "hazardous": ["safe", "non_hazardous"],
  "non_hazardous": ["hazardous"],
  "true": ["false"],
  "false": ["true"],
  "enabled": ["disabled"],
  "disabled": ["enabled"],
  "active": ["inactive", "archived"],
  "inactive": ["active"],
  "archived": ["active"],
  "compliant": ["non_compliant", "violation"],
  "non_compliant": ["compliant"],
  "violation": ["compliant"],
  "approved": ["rejected", "blocked"],
  "rejected": ["approved"],
  "blocked": ["approved"]
}
