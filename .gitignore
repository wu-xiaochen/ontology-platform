# Ignore large files
*.zip
*.png
*.jpg
*.DS_Store

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
*.egg-info/

# Ignore tmp
tmp/

# Ignore .openclaw (local config)
.openclaw/
.clawhub/

# OpenClaw workspace files (local only, not project code)
AGENTS.md
AGENTS.md.bak
SOUL.md
SOUL.md.bak
MEMORY.md
HEARTBEAT.md
BOOTSTRAP.md
IDENTITY.md
TOOLS.md
USER.md
VERSION

# Environment variables - 包含敏感信息如 API Key、密码等，严禁提交到版本控制
.env

# Large database and local data folders
**/data/*.db
**/data/*.sqlite3
**/*.sqlite3
**/chroma_db/
**/mem0_qdrant/
**/audit_lineage.db
**/*.bin
**/*.pyc
**/__pycache__/
