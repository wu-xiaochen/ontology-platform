# Volcengine Ark API Configuration
# 火山引擎 Ark API 配置，用于 LLM 服务调用
# 获取方式：登录火山引擎控制台 -> Ark 平台 -> 创建 API Key
OPENAI_API_KEY=your_api_key_here

# Ark API 基础地址，默认为火山引擎北京节点
# 如需使用其他区域，请参考官方文档修改
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 使用的模型名称，例如：doubao-seed-2-0-pro-260215
# 请在 Ark 平台查看可用的模型列表
OPENAI_MODEL=your_model_name_here

# Neo4j Configuration
# Neo4j 图数据库连接配置，用于存储和查询知识图谱

# Neo4j 连接地址，默认本地 Bolt 协议端口 7687
# 远程部署时请修改为实际地址，如：bolt://your-server:7687
NEO4J_URI=bolt://localhost:7687

# Neo4j 用户名，默认为 neo4j
NEO4J_USER=neo4j

# Neo4j 密码，安装时设置或后续修改的密码
# 注意：生产环境请使用强密码
NEO4J_PASSWORD=your_neo4j_password_here
