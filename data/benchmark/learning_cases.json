[
  {
    "id": "LC01",
    "text": "燃气调压箱是一种将燃气调压器、紧急切断阀、放散阀、过滤器、压力仪表等部件集成在金属箱体内的成套设备。功能：主要用于将上游管网的高压燃气降至下游用户所需的低压标准。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "definition", "entity": "燃气调压箱"},
      {"type": "function", "entity": "燃气调压箱"}
    ]
  },
  {
    "id": "LC02",
    "text": "如果设备是燃气调压箱，那么需要每6个月进行维护检查。如果出口压力超过安全阈值，那么必须立即关闭阀门。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "rule", "condition": "燃气调压箱", "action": "维护检查"},
      {"type": "rule", "condition": "出口压力超过安全阈值", "action": "关闭阀门"}
    ]
  },
  {
    "id": "LC03",
    "text": "楼栋调压箱：通常体积相对较小，壁挂于建筑外墙或设置于专用钢架平台上，主要为单栋或相邻楼宇供气。落地调压柜：通常体积较大，落地安装在地面混凝土基础上，服务范围较广。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "definition", "entity": "楼栋调压箱"},
      {"type": "definition", "entity": "落地调压柜"}
    ]
  },
  {
    "id": "LC04",
    "text": "进口压力：设备允许接入的上游管网压力范围，如0.4-4.0 MPa。出口压力：经设备调节后输出的压力范围，如居民用气2.5-3.0 kPa。额定流量：基准状态下的最大气体流量。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "attribute", "entity": "进口压力"},
      {"type": "attribute", "entity": "出口压力"},
      {"type": "attribute", "entity": "额定流量"}
    ]
  },
  {
    "id": "LC05",
    "text": "糖尿病是一种慢性代谢疾病，主要表现为血糖升高。如果患者空腹血糖高于7.0 mmol/L，那么需要进一步检查糖化血红蛋白。如果糖化血红蛋白超过6.5%，那么确诊为糖尿病。",
    "domain": "medical",
    "expected_patterns": [
      {"type": "definition", "entity": "糖尿病"},
      {"type": "rule", "condition": "空腹血糖高于", "action": "检查糖化血红蛋白"},
      {"type": "rule", "condition": "糖化血红蛋白超过", "action": "确诊为糖尿病"}
    ]
  },
  {
    "id": "LC06",
    "text": "胰岛素是治疗糖尿病的关键药物。如果血糖超过11.1 mmol/L，那么需要注射胰岛素治疗。糖尿病患者需要定期监测血糖。",
    "domain": "medical",
    "expected_patterns": [
      {"type": "definition", "entity": "胰岛素"},
      {"type": "rule", "condition": "血糖超过", "action": "注射胰岛素"}
    ]
  },
  {
    "id": "LC07",
    "text": "调压箱的核心结构包括：模块化集成设计、双路冗余设计、防喘振设计。调压器阀芯采用平衡阀芯结构或两级调压结构。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "composition", "entity": "调压箱"},
      {"type": "definition", "entity": "调压器阀芯"}
    ]
  },
  {
    "id": "LC08",
    "text": "如果调压器出口压力波动大，那么可能是下游用气流量过低引发喘振。如果切断阀动作不灵敏，那么需要检查触发传感器的顶杆位置。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "rule", "condition": "出口压力波动大", "action": "喘振"},
      {"type": "rule", "condition": "切断阀动作不灵敏", "action": "检查触发传感器"}
    ]
  },
  {
    "id": "LC09",
    "text": "同义词：燃气调压柜、调压站设备、楼栋调压箱、区域调压撬。相关物资包括：燃气调压器、流量计、球阀、压力表。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "composition", "entity": "相关物资"}
    ]
  },
  {
    "id": "LC10",
    "text": "居民小区场景：低流量、高安全性要求、用气峰谷差大。采用内置防喘振设计的调压器，具备双重超压保护。如果是居民用户，那么必须选择1+1或更高冗余配置。",
    "domain": "gas_equipment",
    "expected_patterns": [
      {"type": "definition", "entity": "居民小区"},
      {"type": "rule", "condition": "居民用户", "action": "冗余配置"}
    ]
  }
