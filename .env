# ============================================================================
# Ontology Platform 环境配置
# ============================================================================

# ----------------------------------------------------------------------------
# MiniMax API Configuration
# MiniMax CN API 配置，用于 LLM 服务调用（与 Hermes 主环境共用同一 key）
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-cp-HAT4jmJOTA0EPfIhLVD4MSMEiV0v8HmxXfDiIQfyoUx2dekOhh3xDT3WhSh0aL2oGC6svWyNawn4lSeAY6bPSR91vx1OmRIs-lqPyM0vHXgEt4MhcYTo7kg
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M2.7

# ----------------------------------------------------------------------------
# Neo4j Configuration
# Neo4j 图数据库连接配置
# ----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Neo4j 连接池和重试配置
NEO4J_MAX_RETRIES=3
NEO4J_RETRY_DELAY=1.0
NEO4J_CONNECTION_TIMEOUT=30.0
NEO4J_MAX_POOL_SIZE=20
NEO4J_QUERY_TIMEOUT=60.0

# ----------------------------------------------------------------------------
# ChromaDB Configuration
# 向量数据库配置
# ----------------------------------------------------------------------------
CHROMA_PATH=./data/chroma_db
VECTOR_COLLECTION_NAME=clawra_patterns

# ----------------------------------------------------------------------------
# Memory Manager Configuration
# 记忆管理器配置
# ----------------------------------------------------------------------------
MEMORY_SEARCH_TOP_K=5
ENABLE_MEMORY_FALLBACK=true
